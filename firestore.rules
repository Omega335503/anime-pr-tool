rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User's own projects - owner has full access
    // Shared users can read if their email is in the sharedWithEmails array
    match /users/{userId}/projects/{projectId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (resource.data.keys().hasAny(['sharedWithEmails']) &&
         request.auth.token.email in resource.data.sharedWithEmails)
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Sub-collections under projects (raw_docs etc.)
    match /users/{userId}/projects/{projectId}/{subDoc=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Shares collection - any authenticated user can list/read shares
    // (filtering is done in the query with where clause)
    match /shares/{shareId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.sharedWith == request.auth.token.email
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWithUid']))
      );
    }

    // User logs
    match /users/{userId}/logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles
    match /user_profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Bug reports - any authenticated user can create, only admin can read/delete
    match /bug_reports/{reportId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && request.auth.token.email == 'kikuchi.masanari@rasencorp.com';
    }
  }
}
